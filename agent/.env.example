# ─── UniGPU Agent Configuration ───────────────────
# Copy this file to .env and fill in the values.

# Backend WebSocket endpoint
BACKEND_WS_URL=ws://localhost:8000/ws/agent

# Backend HTTP endpoint (for script downloads & artifact uploads)
BACKEND_HTTP_URL=http://localhost:8000

# Agent authentication token (issued by backend on provider registration)
AGENT_TOKEN=your-agent-token-here

# Heartbeat interval in seconds
HEARTBEAT_INTERVAL=10

# Local working directory for job files & outputs
WORK_DIR=./workdir

# Maximum allowed job execution time in seconds
MAX_JOB_TIMEOUT=3600

# Docker base image for training jobs
DOCKER_BASE_IMAGE=pytorch/pytorch:2.1.0-cuda12.1-cudnn8-runtime

# Resource limits
CPU_LIMIT=4.0
MEMORY_LIMIT=8g

# Log batch interval in seconds (lower = more real-time, higher = less network usage)
LOG_BATCH_INTERVAL=0.2
